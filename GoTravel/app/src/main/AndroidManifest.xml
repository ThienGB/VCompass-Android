<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <application
        android:name=".MainApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logo_no_cap"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logo_no_cap"
        android:supportsRtl="true"
        android:theme="@style/Theme.GoTravel"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="33">
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyAS3PJ_faqNzJOVQfNT857SfzRCucS5YMQ"/>
        <service
            android:name=".service.ScheduleNotificationService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <receiver android:name=".broadcast_receiver.SnoozeReceiver" android:exported="false">
            <intent-filter>
                <action android:name="com.yourpackage.SNOOZE_ACTION" />
            </intent-filter>
        </receiver>

        <receiver android:name=".broadcast_receiver.CompleteReceiver" android:exported="false">
            <intent-filter>
                <action android:name="com.yourpackage.COMPLETE_ACTION" />
            </intent-filter>
        </receiver>

        <activity
            android:name=".ui.module.general.login.MainLoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>

                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.module.user.booking.BookingListActivity"
            android:exported="true">
        </activity>

        <activity
            android:name=".ui.module.user.schedule.ScheduleActivity"
            android:exported="true">
        </activity>

        <activity
                android:name=".ui.module.user.main.MainUserActivity"
                android:exported="true">
        </activity>
        <activity
            android:name=".ui.module.admin.main.MainAdminActivity"
            android:exported="true">

        </activity>
        <activity
            android:name=".ui.module.partner.main.MainPartnerActivity"
            android:exported="true">

        </activity>
    </application>

</manifest>